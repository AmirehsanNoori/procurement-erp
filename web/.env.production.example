# Production environment variables for Vercel frontend deployment.
# Copy this to .env.production in the web/ directory, or set these
# as Environment Variables in the Vercel dashboard.

# When the frontend and backend are on the same Vercel deployment,
# the API is at /api (same origin — no CORS needed).
VITE_API_URL=/api

# If your backend is deployed separately (e.g., Railway/Render):
# VITE_API_URL=https://your-api.railway.app/api
