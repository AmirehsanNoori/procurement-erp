# ---- Database ----
# When using docker-compose (default), these match docker-compose.yml.
POSTGRES_USER=erp
POSTGRES_PASSWORD=erp_password
POSTGRES_DB=procurement_erp
POSTGRES_PORT=5432

# Prisma connection string. If you use docker-compose on localhost, this works as-is.
DATABASE_URL="postgresql://erp:erp_password@localhost:5432/procurement_erp?schema=public"

# ---- Server ----
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins (the Vite dev server)
CORS_ORIGINS=http://localhost:5173

# ---- Auth (CHANGE THESE IN PRODUCTION) ----
JWT_ACCESS_SECRET=change-me-access-secret-please
JWT_REFRESH_SECRET=change-me-refresh-secret-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=10

# ---- File storage ----
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20

# ---- Initial admin (created by seed) ----
ADMIN_EMAIL=admin@procurement.local
ADMIN_PASSWORD=Admin@12345
ADMIN_FULL_NAME=System Administrator
