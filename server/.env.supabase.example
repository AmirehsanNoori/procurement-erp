# ── Supabase Database ──────────────────────────────────────────────────────────
#
# From Supabase dashboard → Project Settings → Database → Connection String
#
# 1. "Transaction" mode (via pgBouncer) — used for Prisma CLIENT queries:
#    Port 6543, includes ?pgbouncer=true
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=20"

# 2. Direct connection — used for Prisma MIGRATIONS (prisma migrate deploy):
#    Port 5432, no pgbouncer param
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# On Vercel, allow the Vercel frontend URL (or * for same-origin deployments)
CORS_ORIGINS=https://your-project.vercel.app

# ── Auth (CHANGE THESE — use strong random secrets in production) ───────────
JWT_ACCESS_SECRET=CHANGE_ME_random_64_char_secret
JWT_REFRESH_SECRET=CHANGE_ME_another_random_64_char_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# ── File storage ──────────────────────────────────────────────────────────────
# On Vercel serverless, use /tmp for temporary storage (files don't persist).
# For production document storage, integrate Supabase Storage (S3-compatible).
UPLOAD_DIR=/tmp/erp-uploads
MAX_UPLOAD_MB=20

# ── Initial admin (only used by seed — change before running db:seed) ─────────
ADMIN_EMAIL=admin@your-company.com
ADMIN_PASSWORD=YourStrongPassword@123
ADMIN_FULL_NAME=System Administrator
